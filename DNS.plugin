# > Cloudflare
# refer: https://developers.cloudflare.com/1.1.1.1/encryption/dns-over-https/make-api-requests/
*.cloudflare.com = server:https://1.1.1.1/dns-query
# Cloudflare Stream
*.cloudflarestream.com = server:https://1.1.1.1/dns-query
# Cloudflare Client
*.cloudflareclient.com = server:https://1.1.1.1/dns-query
# Cloudflare Web Analytics
*.cloudflareinsights.com = server:https://1.1.1.1/dns-query
# Cloudflare 1.1.1.1
*.every1dns.net = server:https://1.1.1.1/dns-query
# Cloudflare SSL Certificate
*.cloudflaressl.com = server:https://1.1.1.1/dns-query
# Cloudflare DNS
*.cloudflare-dns.com = server:https://1.1.1.1/dns-query
# CloudFlare Workers
*.workers.dev = server:https://1.1.1.1/dns-query

# > 🇹🇼 TWN
# 中华电信
*.cht.com.tw = server:https://dns.hinet.net/dns-query
# 中华电信HiNet
*.hinet.net = server:https://dns.hinet.net/dns-query
# 中华电信emome
*.emome.net = server:https://dns.hinet.net/dns-query

#!name=🍟 Fries: 🌐 DNS enhanced
#!desc=1.域名按所属DNS进行分流解析 2.路由器地址使用系统DNS进行解析 3.特殊地址使用规范DNS进行解析
#!author=VirgilClyne
#!homepage=https://github.com/VirgilClyne/GetSomeFries/wiki/🌐-DNS
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Server.png
#!category=🍟 Fries

[General]

[Host]
# --- CUSTOM HOSTS ---
# > IPv6
ip6-localhost = ::1
ip6-loopback = ::1
ip6-localnet = fe00::0
ip6-mcastprefix = ff00::0
ip6-allnodes = ff02::1
ip6-allrouters = ff02::2
ip6-allhosts = ff02::3

# > Encrypted DNS
dns.google = 8.8.8.8
dns64.dns.google = 2001:4860:4860::6464
cloudflare-dns.com = 104.16.249.249
1dot1dot1dot1.cloudflare-dns.com = 1.1.1.1
one.one.one.one = 1.1.1.1
dns.alidns.com = 223.5.5.5
doh.pub = 1.12.12.12
dot.pub = 1.12.12.12
doh.360.cn = 23.6.48.18
dot.360.cn = 101.198.198.198
dns.twnic.tw = 101.101.101.101
ordns.he.net = 74.82.42.42

# > Modify Contents
# Google API Services China
# services.googleapis.cn = 74.125.193.94
# Firebase Cloud Messaging
talk.google.com = 108.177.125.188
mtalk.google.com = 108.177.125.188
alt1-mtalk.google.com = 3.3.3.3
alt2-mtalk.google.com = 3.3.3.3
alt3-mtalk.google.com = 74.125.200.188
alt4-mtalk.google.com = 74.125.200.188
alt5-mtalk.google.com = 3.3.3.3
alt6-mtalk.google.com = 3.3.3.3
alt7-mtalk.google.com = 74.125.200.188
alt8-mtalk.google.com = 3.3.3.3
# Google CDN
dl.google.com = 180.163.151.161
dl.l.google.com = 180.163.151.161

# --- CUSTOM DNS ---
# > Modify Contents
# Google CDN
blog.google = server:https://1.12.12.12/dns-query
googletraveladservices.com = server:https://1.12.12.12/dns-query
dl.google.com = server:https://1.12.12.12/dns-query
dl.l.google.com = server:https://1.12.12.12/dns-query
clientservices.googleapis.com = server:https://1.12.12.12/dns-query
update.googleapis.com = server:https://1.12.12.12/dns-query
translate。googleapis.com = server:https://1.12.12.12/dns-query
fonts.googleapis.com = server:https://1.12.12.12/dns-query
fonts.gstatic.com = server:https://1.12.12.12/dns-query
# Google STUN
stun.l.google.com = server:system
stun?.l.google.com = server:system

# > Apple
# refer: https://support.apple.com/zh-cn/HT210060
networking.apple = server:https://doh.dns.apple.com/dns-query
# Apple.com
*.apple.com = server:https://doh.dns.apple.com/dns-query
# iCloud.com
*.icloud。com = server:https://doh.dns.apple.com/dns-query

# > Alphabet
# refer: https://developers.google.com/speed/public-dns/docs/doh?hl=zh-cn
*.google = server:https://8.8.8.8/dns-query
*.google.com = server:https://8.8.8.8/dns-query
*.google.com.?? = server:https://8.8.8.8/dns-query
# Google sites
*.goog = server:https://8.8.8.8/dns-query
# Google 静态资源
*.gstatic.com = server:https://8.8.8.8/dns-query
# Google Photos
*.ggpht.com = server:https://8.8.8.8/dns-query
# Google 用户上传数据
*.googleusercontent.com = server:https://8.8.8.8/dns-query
# Google APIs
*.googleapis.com = server:https://8.8.8.8/dns-query
# Google backbone
*.1e100.net = server:https://8.8.8.8/dns-query
# Youtube sites
*.youtube = server:https://8.8.8.8/dns-query
# Youtube
*.youtube.com = server:https://8.8.8.8/dns-query
# Youtube 图片
*.ytimg.com = server:https://8.8.8.8/dns-query
# Youtube Video
*.googlevideo.com = server:https://8.8.8.8/dns-query
# Google Video Thumbnails
*.gvt?.com = server:https://8.8.8.8/dns-query
# reCaptcha
*.recaptcha.net = server:https://8.8.8.8/dns-query
# Gmail
*.gmail.com = server:https://8.8.8.8/dns-query
# Google Source
*.googlesource.com = server:https://8.8.8.8/dns-query
# Google AD Services
*.googleadservices.com = server:https://8.8.8.8/dns-query
# DoubleClick
*.doubleclick.net = server:https://8.8.8.8/dns-query
# AdSense
*.adsense.com = server:https://8.8.8.8/dns-query
# AdSense Custom Search Ads
*.adsensecustomsearchads.com = server:https://8.8.8.8/dns-query
